{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PortKiller",
  "version": "1.0.0",
  "identifier": "com.portkiller.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "node scripts/embed-icon.cjs"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "PortKiller",
        "url": "index.html",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "visible": false,
        "skipTaskbar": false,
        "center": true,
        "width": 580,
        "height": 680,
        "minWidth": 460,
        "minHeight": 460,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "fullscreen": false,
        "focus": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "shortDescription": "Port Process Killer Utility",
    "longDescription": "The fastest way for developers to visualize and terminate processes locking specific ports",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "targets": "all",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"]
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
